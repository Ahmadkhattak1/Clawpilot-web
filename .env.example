# Public variables exposed to the browser.
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional analytics (set one or both).
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Optional runtime debug logs in the browser.
# Set to 1 to force logs in production builds.
NEXT_PUBLIC_RUNTIME_DEBUG=0

# Server-side variables for Next.js API routes.
# BACKEND_API_URL can be a private/internal URL reachable by the server runtime.
BACKEND_API_URL=http://localhost:4000

# Optional public base URL used to normalize launch URLs returned by backend.
# Leave empty to use NEXT_PUBLIC_BACKEND_API_URL.
BACKEND_PUBLIC_API_URL=

# Must match backend INTERNAL_API_TOKEN.
BACKEND_INTERNAL_API_TOKEN=dev-internal-token
